FORTIVPN_HOST="vpn.example.com"
FORTIVPN_TRUSTED_CERT="trusted-cert-hash"
FORTIVPN_USERNAME="username"
FORTIVPN_PASSWORD="password"
VPN_WATCH_TARGET="ssh-alias-or-host"

# Optional tuning (defaults shown; safe to omit):
# FORTIVPN_READY_TIMEOUT=60   # seconds the daemon waits for network/DNS before launching
# VPN_WATCH_COOLDOWN=60       # seconds the watchdog waits between forced restarts
